{
    "name": "elmasry/starter-kit",
    "description": "Laravel Starter Kit with Filament v5, Multi-Language (AR/EN), Roles & Permissions, and essential dashboard features for all Laravel projects",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Elmasry",
            "email": "dev@elmasry.dev"
        }
    ],
    "autoload": {
        "psr-4": {
            "Elmasry\\StarterKit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Elmasry\\StarterKit\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Elmasry\\StarterKit\\StarterKitServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.28|^12.0|^13.0",
        "livewire/livewire": "^4.0",
        "filament/filament": "^5.0",
        "spatie/laravel-permission": "^8.0",
        "spatie/laravel-translatable": "^6.0",
        "spatie/laravel-medialibrary": "^11.0",
        "spatie/laravel-activitylog": "^4.12",
        "mcamara/laravel-localization": "^2.0",
        "spatie/laravel-sluggable": "^3.0",
        "spatie/laravel-sitemap": "^7.0",
        "spatie/laravel-cookie-consent": "^3.0",
        "spatie/laravel-honeypot": "^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.0"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
