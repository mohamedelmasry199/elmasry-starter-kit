{
    "name": "elmasry/starter-kit",
    "description": "Laravel Starter Kit with Filament, Multi-Language (AR/EN), Roles & Permissions, and essential dashboard features for all Laravel projects",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Elmasry",
            "email": "dev@elmasry.dev"
        }
    ],
    "autoload": {
        "psr-4": {
            "Elmasry\\StarterKit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Elmasry\\StarterKit\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Elmasry\\StarterKit\\StarterKitServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.1",
        "laravel/framework": "^10.0|^11.0",
        "filament/filament": "^3.0",
        "filament/spatie-laravel-ignition": "^3.0",
        "spatie/laravel-permission": "^6.0",
        "spatie/laravel-translatable": "^6.0",
        "spatie/laravel-medialibrary": "^10.0|^11.0",
        "spatie/laravel-activitylog": "^4.0",
        "mcamara/laravel-localization": "^1.6|^2.0",
        "spatie/laravel-sluggable": "^3.0",
        "spatie/laravel-sitemap": "^7.0",
        "spatie/laravel-cookie-consent": "^3.0",
        "spatie/laravel-honeypot": "^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
